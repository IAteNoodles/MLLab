   "source": [
    "import csv\n",
    "\n",
    "with open(\"Training_Data.csv\") as f:\n",
    "    data = [r for r in csv.reader(f) if r[-1].lower()==\"yes\"]\n",
    "\n",
    "hypo = data[0][:-1]\n",
    "\n",
    "for row in data[1:]:\n",
    "    hypo = [x if x==y else '?' for x,y in zip(hypo,row[:-1])]\n",
    "    print(hypo)\n",
    "\n",
    "print(\"\\nFinal Hypothesis:\", hypo)\n"
   ]
  }
